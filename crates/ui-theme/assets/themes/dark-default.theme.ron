// dark-default — RGE base dark theme.
// adapted from rustforge::apps::editor-app::egui_overlay on 2026-05-05
// — extracted ThemeRegistry. Slightly desaturated near-black surfaces
// with a teal accent, tuned to pass WCAG AA against `color.foreground`
// and `color.text.muted` on every container colour.
(
    name: "dark-default",
    version: 1,
    extends: None,
    variants: [],
    tokens: {
        // -- colour: containers ------------------------------------
        "color.background":
            Color((srgb: (20, 20, 20, 255), linear: (0.00605, 0.00605, 0.00605, 1.0))),
        "color.surface":
            Color((srgb: (32, 32, 34, 255), linear: (0.01444, 0.01444, 0.01620, 1.0))),
        "color.panel":
            Color((srgb: (24, 24, 28, 255), linear: (0.00866, 0.00866, 0.01084, 1.0))),

        // -- colour: typography ------------------------------------
        "color.foreground":
            Color((srgb: (240, 240, 240, 255), linear: (0.87137, 0.87137, 0.87137, 1.0))),
        "color.text.muted":
            Color((srgb: (170, 170, 170, 255), linear: (0.40197, 0.40197, 0.40197, 1.0))),

        // -- colour: accent ----------------------------------------
        "color.accent":
            Color((srgb: (27, 111, 184, 255), linear: (0.01024, 0.16121, 0.46778, 1.0))),
        "color.accent.on":
            Color((srgb: (255, 255, 255, 255), linear: (1.0, 1.0, 1.0, 1.0))),

        // -- colour: status ----------------------------------------
        "color.success":
            Color((srgb: (74, 200, 130, 255), linear: (0.06480, 0.57112, 0.21953, 1.0))),
        "color.warning":
            Color((srgb: (220, 170, 60, 255), linear: (0.69538, 0.40197, 0.04519, 1.0))),
        "color.error":
            Color((srgb: (220, 90, 90, 255), linear: (0.69538, 0.09531, 0.09531, 1.0))),

        // -- length: spacing ---------------------------------------
        "length.spacing.xs": Length(Px(2.0)),
        "length.spacing.sm": Length(Px(4.0)),
        "length.spacing.md": Length(Px(8.0)),
        "length.spacing.lg": Length(Px(12.0)),
        "length.spacing.xl": Length(Px(16.0)),

        // -- length: radius ----------------------------------------
        "length.radius.sm": Length(Px(2.0)),
        "length.radius.md": Length(Px(4.0)),
        "length.radius.lg": Length(Px(8.0)),

        // -- font --------------------------------------------------
        "font.body": Font((
            family: "Inter",
            size: Pt(11.0),
            weight: Regular,
        )),
        "font.heading": Font((
            family: "Inter",
            size: Pt(14.0),
            weight: SemiBold,
        )),
        "font.mono": Font((
            family: "JetBrains Mono",
            size: Pt(11.0),
            weight: Regular,
        )),

        // -- padding -----------------------------------------------
        "padding.button": Padding((
            top: Px(4.0), right: Px(8.0), bottom: Px(4.0), left: Px(8.0),
        )),

        // -- shadow ------------------------------------------------
        "shadow.popup": Shadow((
            offset_x: 0.0,
            offset_y: 4.0,
            blur: 12.0,
            spread: 0.0,
            color: (
                srgb: (0, 0, 0, 96),
                linear: (0.0, 0.0, 0.0, 0.376),
            ),
        )),

        // -- motion ------------------------------------------------
        "motion.fade.in":     Animation((duration_ms: 180, curve: EaseOut)),
        "motion.fade.out":    Animation((duration_ms: 120, curve: EaseIn)),
        "motion.menu.expand": Animation((duration_ms: 140, curve: EaseOut)),
        "motion.tab.switch":  Animation((duration_ms: 100, curve: Linear)),

        // -- opacity -----------------------------------------------
        "opacity.disabled": Opacity(0.40),
        "opacity.hover":    Opacity(0.92),
    },
    styles: {
        "Button": (slots: {
            "background": TokenRef("color.surface"),
            "foreground": TokenRef("color.foreground"),
            "padding":    TokenRef("padding.button"),
            "radius":     TokenRef("length.radius.md"),
        }),
        "Button.Primary": (slots: {
            "background": TokenRef("color.accent"),
            "foreground": TokenRef("color.accent.on"),
            "padding":    TokenRef("padding.button"),
            "radius":     TokenRef("length.radius.md"),
        }),
        "Panel": (slots: {
            "background": TokenRef("color.panel"),
            "foreground": TokenRef("color.foreground"),
        }),
    },
)
